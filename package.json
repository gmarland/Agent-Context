{
  "name": "symlink-extension",
  "displayName": "Agent Folders",
  "description": "Attach external reference folders to your workspace for agent and developer context",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agentFolders"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentFoldersSidebar",
          "title": "Agent Folders",
          "icon": "media/symlink-folders.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "agentFolders.addFolder",
        "title": "Add Agent Folder",
        "icon": "$(add)"
      },
      {
        "command": "agentFolders.removeFolder",
        "title": "Remove Agent Folder",
        "icon": "$(trash)"
      },
      {
        "command": "agentFolders.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "agentFolders.openFolderDirectory",
        "title": "Open Agent Folders Directory",
        "icon": "$(folder-opened)"
      },
      {
        "command": "agentFolders.revealOriginalFolder",
        "title": "Reveal Original Folder",
        "icon": "$(file-symlink-directory)"
      },
      {
        "command": "agentFolders.editDescription",
        "title": "Edit Description",
        "icon": "$(edit)"
      }
    ],
    "views": {
      "agentFoldersSidebar": [
        {
          "id": "agentFolders",
          "name": "Attached Folders"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentFolders",
        "contents": "No folders are attached yet.\n[Add Folder](command:agentFolders.addFolder)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentFolders.addFolder",
          "when": "view == agentFolders",
          "group": "navigation"
        },
        {
          "command": "agentFolders.refresh",
          "when": "view == agentFolders",
          "group": "navigation"
        },
        {
          "command": "agentFolders.openFolderDirectory",
          "when": "view == agentFolders",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentFolders.removeFolder",
          "when": "view == agentFolders && viewItem == agentFolderItem",
          "group": "inline"
        },
        {
          "command": "agentFolders.editDescription",
          "when": "view == agentFolders && viewItem == agentFolderItem",
          "group": "inline"
        },
        {
          "command": "agentFolders.revealOriginalFolder",
          "when": "view == agentFolders && viewItem == agentFolderItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Agent Folders",
      "properties": {
        "agentFolders.targetFolder": {
          "type": "string",
          "default": ".examples",
          "description": "The folder within the workspace where agent folder symlinks will be created"
        },
        "agentFolders.updateAgentInstructions": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update the shared instructions file when folders are added or removed"
        },
        "agentFolders.instructionsFile": {
          "type": "string",
          "default": "AGENTS.md",
          "description": "Relative path within the workspace to the shared instructions file to update"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node --test test/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
